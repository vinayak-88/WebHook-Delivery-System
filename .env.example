PORT=3000
MONGODB_URI=mongodb://localhost:27017/webhook-delivery
REDIS_HOST=localhost
REDIS_PORT=6379
NODE_ENV=development
RECOVERY_INTERVAL_MS=5000
RECOVERY_BATCH_SIZE=25
# Minimum 32 characters — enforced at subscriber registration
WEBHOOK_SECRET=your-minimum-32-character-secret-here
# Set to true on all but one API instance when running multiple replicas
# to prevent concurrent recovery scans. Use Redlock before scaling out fully.
DISABLE_RECOVERY=false
